// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  address   String?
  pets      Pet[]
  appointments Appointment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pet {
  id          String       @id @default(cuid())
  name        String
  species     String
  breed       String?
  birthDate   DateTime?
  weight      Float?
  chipNumber  String?      @unique
  photoUrl    String?
  clientId    String
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  medicalHistory MedicalRecord[]
  appointments   Appointment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model MedicalRecord {
  id          String   @id @default(cuid())
  petId       String
  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  date        DateTime @default(now())
  diagnosis   String
  treatment   String
  notes       String?
  vetName     String
  createdAt   DateTime @default(now())
}

model Appointment {
  id        String            @id @default(cuid())
  clientId  String
  client    Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  petId     String
  pet               Pet               @relation(fields: [petId], references: [id], onDelete: Cascade)
  date      DateTime
  service   ServiceType
  status    AppointmentStatus @default(PENDING)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model Service {
  id          String  @id @default(cuid())
  name        String
  description String
  price       Float
  imageUrl    String?
  active      Boolean @default(true)
}

enum Role {
  ADMIN
  STAFF
}

enum ServiceType {
  CONSULTA
  ESTETICA
  BANO
  CIRUGIA_MENOR
  VACUNACION
  DESPARASITACION
  OTRO
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}
