# =========================================================
# apps/api — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitas el .env con valores reales al repositorio.
# =========================================================

# --- Base de datos (Neon PostgreSQL) ---
# Conexión CON pooling (PgBouncer) — usar en runtime / Render / producción
DATABASE_URL="postgresql://usuario:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# Conexión DIRECTA — solo para prisma migrate / db push
DIRECT_URL="postgresql://usuario:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# --- Cloudflare R2 (almacenamiento de imágenes) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT="https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_BUCKET_NAME="veterinaria-codorniz-productos"
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# --- JWT ---
JWT_SECRET="secreto_aleatorio_min_32_caracteres"
JWT_REFRESH_SECRET="otro_secreto_diferente_min_32_caracteres"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Admin inicial (seed) ---
ADMIN_EMAIL="admin@veterinariacodorniz.com"
ADMIN_PASSWORD="CambiarEsto_ConPassword_Seguro123!"

# --- Servidor ---
PORT=3001
# URL pública del frontend (para CORS)
FRONTEND_URL="https://tu-dominio.vercel.app"
NODE_ENV="production"
