# === Neon (PostgreSQL) ===
# Connection string con pooling (PgBouncer). Usar en runtime de la API / producción.
# Dashboard Neon -> Connection Details -> "Pooled connection".
DATABASE_URL="postgresql://usuario:password@ep-xxxx-pooler.region.aws.neon.tech/nombre_db?sslmode=require"

# Connection string SIN pooling. Solo para migraciones Prisma (db push / migrate).
DIRECT_URL="postgresql://usuario:password@ep-xxxx.region.aws.neon.tech/nombre_db?sslmode=require"

# === Cloudflare R2 (compatible con S3) ===
# Dashboard Cloudflare -> R2 -> Manage R2 API Tokens
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# Endpoint: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=""
# Bucket de imágenes de productos y mascotas (ej. veterinaria-codorniz-productos)
R2_BUCKET_NAME=""
# URL pública del bucket (r2.dev o dominio custom)
R2_PUBLIC_URL=""

# === JWT (API) ===
JWT_SECRET="cambiar_por_secreto_largo_aleatorio_min_32_chars"
JWT_REFRESH_SECRET="otro_secreto_diferente_largo_aleatorio"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"

# === Admin inicial (seed) ===
ADMIN_EMAIL="admin@veterinariacodorniz.com"
ADMIN_PASSWORD="CambiarEsto123!"

# === URLs ===
# URL pública del frontend (CORS)
FRONTEND_URL="http://localhost:12345"
# URL de la API que consume el frontend Next.js
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
PORT=3001

# === Contacto / redes (frontend) ===
NEXT_PUBLIC_WHATSAPP_NUMBER=""
NEXT_PUBLIC_WHATSAPP_MESSAGE=""
NEXT_PUBLIC_FACEBOOK_URL=""
NEXT_PUBLIC_INSTAGRAM_URL=""
NEXT_PUBLIC_CONTACT_EMAIL=""
CONTACT_EMAIL=""
