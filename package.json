{
  "name": "veterinaria-la-codorniz",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "web:dev": "npm run dev --workspace=apps/web",
    "api:dev": "npm run dev --workspace=apps/api",
    "web:build": "npm run build --workspace=apps/web",
    "api:build": "npm run build --workspace=apps/api",
    "db:generate": "npm run prisma:generate --workspace=apps/api",
    "db:push": "npm run prisma:push --workspace=apps/api",
    "db:seed": "npm run seed --workspace=apps/api",
    "db:studio": "npm run prisma:studio --workspace=apps/api"
  }
}
